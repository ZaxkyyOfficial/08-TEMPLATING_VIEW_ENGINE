<!DOCTYPE html>
<html lang="id">
    <head>
        <meta charset="UTF-8" />
        <title>Hapus Produk</title>
        <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
        rel="stylesheet"
        />
    </head>
    <body>
        <div class="container mt-5">
        <h3>Yakin ingin menghapus produk &ldquo;<%= nama_produk %>&rdquo;?</h3>
        <form action="/produk/destroy/<%= id_produk %>" method="POST">
            <button type="submit" class="btn btn-sm btn-danger">Ya, hapus</button>
            <a href="/produk" class="btn btn-sm btn-secondary">Batal</a>
        </form>
        </div>
    </body>
</html>
