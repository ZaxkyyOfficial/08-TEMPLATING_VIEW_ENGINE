<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Produk</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<div class="container mt-5">
    <div class="card">
        <div class="card-header bg-warning">
            <h4>Edit Produk</h4>
        </div>
        <div class="card-body">
            <form action="/produk/update/<%= id_produk %>" method="POST" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="nama" class="form-label">Nama Produk</label>
                    <input type="text" class="form-control" name="nama_produk" value="<%= nama_produk %>" required>
                </div>
                <div class="mb-3">
                    <label for="foto" class="form-label">Foto Produk (ubah jika ingin mengganti)</label>
                    <input type="file" class="form-control" name="foto" accept="image/*">
                    <% if (foto) { %>
                        <p class="mt-2">Foto saat ini:</p>
                        <img src="<%= foto %>" alt="Foto Produk" style="width: 120px; height: 120px; object-fit: cover; border-radius: 4px;" />
                    <% } else { %>
                        <p class="mt-2 text-muted">Belum ada foto</p>
                    <% } %>
                </div>
                
                <div class="mb-3">
                    <label for="harga" class="form-label">Harga</label>
                    <input type="number" class="form-control" name="harga" value="<%= harga %>" required>
                </div>
                
                <div class="mb-3">
                    <label for="kategori" class="form-label">Kategori</label>
                    <select class="form-select" name="id_kategori" required>
                        <option value="">-- Pilih Kategori --</option>
                        <% categories.forEach(function(cat){ %>
                        <option value="<%= cat.id_kategori %>" <%= cat.id_kategori == id_kategori ? 'selected' : '' %>>
                            <%= cat.nama_kategori %>
                        </option>
                        <% }) %>
                    </select>
                </div>
                
                <div class="mt-4">
                    <button type="submit" class="btn btn-warning">Update Produk</button>
                    <a href="/produk" class="btn btn-secondary">Batal</a>
                </div>
            </form>
        </div>
    </div>
</div>
</body>
</html>