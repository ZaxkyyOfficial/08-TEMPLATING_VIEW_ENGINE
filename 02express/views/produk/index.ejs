<%- include('../partials/_head') %>

<div class="container-xl mt-5">
    
    <% if (messages.success) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <%- messages.success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    <% } %>

    <div class="table-responsive">
        <div class="table-wrapper">
            <div class="table-title mb-3">
                <div class="row align-items-center">
                    <div class="col-sm-6">
                        <h2>Manage <b>Produk</b></h2>
                    </div>
                    <div class="col-sm-6 text-end d-flex justify-content-end gap-2">
                        <a href="/produk/create" class="btn btn-success"><i class="fas fa-plus-circle"></i> <span>Add New Produk</span></a>
                    </div>
                </div>
            </div>
            <table class="table table-striped table-hover table-bordered">
                <thead class="table-dark">
                    <tr>
                        <th>No</th>
                        <th>Nama</th>
                        <th>Harga</th>
                        <th>Kategori</th>
                        <th>Foto</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (produk && produk.length > 0) { %>
                        <% produk.forEach(function(item, index) { %>
                        <tr>
                            <td><%= ((currentPage - 1) * 10) + index + 1 %></td> 
                            <td><%= item.nama %></td>
                            <td><%= item.harga %></td>
                            <td><%= item.kategori %></td>
                            <td>
                                <% if (item.foto) { %>
                                <img src="<%= item.foto %>" alt="Foto <%= item.nama %>" style="width:60px;height:60px;object-fit:cover;border-radius:5px;" />
                                <% } else { %>
                                -
                                <% } %>
                            </td>
                            <td>
                                <a href="/produk/edit/<%= item.no %>" class="edit text-warning me-2" title="Edit"><i class="fas fa-pen"></i></a>
                                <a href="/produk/delete/<%= item.no %>" class="delete text-danger" title="Delete"><i class="fas fa-trash"></i></a>
                            </td>
                        </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="text-center">Belum ada data produk.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>

            <div class="clearfix d-flex justify-content-between align-items-center">
                <div class="hint-text">
                    Showing <b><%= produk.length %></b> of <b><%= totalData %></b> entries (Page <b><%= currentPage %></b> of <b><%= totalPages %></b>)
                </div>
                <ul class="pagination mb-0">
                    <% if (currentPage > 1) { %>
                        <li class="page-item">
                            <a href="/produk?page=<%= currentPage - 1 %>" class="page-link">Previous</a>
                        </li>
                    <% } else { %>
                        <li class="page-item disabled">
                            <a href="#" class="page-link">Previous</a>
                        </li>
                    <% } %>

                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <% if (i === currentPage) { %>
                            <li class="page-item active">
                                <a href="#" class="page-link"><%= i %></a>
                            </li>
                        <% } else { %>
                            <li class="page-item">
                                <a href="/produk?page=<%= i %>" class="page-link"><%= i %></a>
                            </li>
                        <% } %>
                    <% } %>

                    <% if (currentPage < totalPages) { %>
                        <li class="page-item">
                            <a href="/produk?page=<%= currentPage + 1 %>" class="page-link">Next</a>
                        </li>
                    <% } else { %>
                        <li class="page-item disabled">
                            <a href="#" class="page-link">Next</a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>

<%- include('../partials/_foot') %>